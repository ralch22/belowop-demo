# Dependencies
node_modules/

# Build output
.next/
out/
dist/

# Test output
tsconfig.tsbuildinfo
next-env.d.ts

# Local env / secrets — never commit
.env
.env.local
.env.*.local
.env.production.local
.env.development.local

# Vercel project link (contains project id)
.vercel/

# RERA broker registry source export — carries personal data (names, office
# phone numbers). Imported into Postgres via db/import-brokers.ts; never
# committed or bundled. (data/listings.json IS tracked — it's synthetic seed.)
data/brokers.csv
*.csv

# OS / IDE
.DS_Store
Thumbs.db
.vscode/
.idea/
*.swp
*~

# Office lock files (transient, created while a doc is open)
~$*

# Local-only editor/agent launch config (not part of the app)
.claude/launch.json

# next-pwa generated artifacts (built from manifest at build time)
public/sw.js
public/workbox-*.js
public/sw.js.map
public/workbox-*.js.map
public/fallback-*.js

# Generated icon set (built from sources via scripts/gen-icons.ts)
# Keep the SVG sources; PNG/maskable variants are regenerated each build.
# public/icons/icon-*.png      # uncomment if you want to ignore the rasters
# public/icons/maskable-*.png

# Logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# Editor-specific
.history/
